---
import Base from '../layouts/Base.astro';
---
<Base title="RoboCup@Home — Teams" description="RoboCup@Home teams from universities and institutions around the world.">
  <link slot="head" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="page-tag">Global Community</div>
    <div class="page-title">Teams around the world.</div>
    <p class="page-desc">RoboCup@Home brings together research teams from universities and institutions across the globe. Click a pin to learn more about each team.</p>
  </div>

  <!-- MAP -->
  <div class="map-section">
    <div id="activity-slider-wrap" style="padding:0 0 1.25rem;"></div>
    <div id="map"></div>
  </div>

  <!-- TEAM LIST -->
  <div class="teams-section">
    <div class="section-label">Participating Teams</div>
    <div class="teams-grid" id="teams-grid">
      <div style="color:var(--muted);font-size:14px;padding:1rem 0;">Loading teams…</div>
    </div>
  </div>
</Base>

<script>
  import L from 'leaflet';
  import { db, ensureAuth } from '../lib/firebase';
  import { getDocs, collection } from 'firebase/firestore';

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
  const map = L.map('map', { zoomControl: true, scrollWheelZoom: false }).setView([20, 10], 2);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '© OpenStreetMap © CARTO',
    maxZoom: 18,
  }).addTo(map);

  const markerIcon = L.divIcon({
    className: '',
    html: `<div style="width:12px;height:12px;border-radius:50%;background:#3b82f6;border:2px solid #fff;box-shadow:0 0 6px rgba(59,130,246,0.6);"></div>`,
    iconSize: [12, 12],
    iconAnchor: [6, 6],
  });

  let allTeams: any[]          = [];
  let teamLastYear: Record<string, number> = {};
  let markers: Record<string, L.Marker>   = {};
  let activeMinYear = 2022;
  const CURRENT_YEAR = new Date().getFullYear();

  function updateMapAndGrid(minYear: number) {
    activeMinYear = minYear;
    const labelEl = document.getElementById('slider-label');
    if (labelEl) labelEl.textContent = minYear <= 2006 ? 'All time' : `Active since ${minYear}`;

    const grid = document.getElementById('teams-grid')!;
    grid.innerHTML = '';

    for (const team of allTeams) {
      const lastYear = teamLastYear[team.id] ?? CURRENT_YEAR;
      const visible  = lastYear >= minYear;

      if (markers[team.id]) {
        if (visible) markers[team.id].addTo(map);
        else         markers[team.id].remove();
      }
      if (!visible) continue;

      const websiteLink = team.website ? `<a href="${team.website}" target="_blank" class="team-link">Website ↗</a>` : '';
      const tdpLink     = team.tdp && team.tdp !== 'Placeholder'
        ? `<a href="${team.tdp}" target="_blank" class="team-link">TDP ↗</a>` : '';

      const card = document.createElement('div');
      card.className = 'team-card';
      card.innerHTML = `
        <a href="${BASE}/team?id=${team.id}&from=teams" style="text-decoration:none;color:inherit;">
          <div class="team-name">${team.name}</div>
          <div class="team-institution">${team.institution || ''}</div>
          <div class="team-location">${[team.city, team.country].filter(Boolean).join(', ')}</div>
          <div class="team-links">${websiteLink}${tdpLink}</div>
        </a>`;
      grid.appendChild(card);
    }
  }

  async function load() {
    await ensureAuth();

    const [teamsSnap, compsSnap] = await Promise.all([
      getDocs(collection(db, 'teams')),
      getDocs(collection(db, 'competitions')),
    ]);

    for (const d of compsSnap.docs) {
      const comp = d.data();
      const year = parseInt(comp.year) || 0;
      if (!year) continue;
      for (const t of (comp.participatingTeams || [])) {
        if (!teamLastYear[t.teamId] || year > teamLastYear[t.teamId]) teamLastYear[t.teamId] = year;
      }
      for (const p of (comp.podium || [])) {
        if (p.teamId && (!teamLastYear[p.teamId] || year > teamLastYear[p.teamId])) teamLastYear[p.teamId] = year;
      }
    }

    allTeams = teamsSnap.docs
      .map(d => ({ id: d.id, ...d.data() }))
      .filter((t: any) => t.name)
      .sort((a: any, b: any) => (a.name || '').localeCompare(b.name || ''));

    // Build year slider
    const sliderWrap = document.getElementById('activity-slider-wrap')!;
    sliderWrap.innerHTML = `
      <div class="slider-row">
        <span class="filter-label">Show teams</span>
        <input type="range" id="activity-slider" min="2005" max="${CURRENT_YEAR}" value="2022" step="1"
          style="flex:1;margin:0 1rem;" />
        <span id="slider-label" style="font-family:var(--font-head);font-size:13px;min-width:120px;">Active since 2022</span>
      </div>`;
    document.getElementById('activity-slider')!.addEventListener('input', e => {
      updateMapAndGrid(parseInt((e.target as HTMLInputElement).value));
    });

    // Build map markers
    for (const team of allTeams) {
      const { lat, lng } = team;
      if (lat == null || lng == null || isNaN(lat) || isNaN(lng)) continue;

      const lastSeen    = teamLastYear[team.id] ? `Last participated: ${teamLastYear[team.id]}` : '';
      const websiteLink = team.website ? `<a href="${team.website}" target="_blank" style="color:#3b82f6;font-family:monospace;font-size:12px;">Website ↗</a>` : '';
      const tdpLink     = team.tdp && team.tdp !== 'Placeholder' ? `<a href="${team.tdp}" target="_blank" style="color:#3b82f6;font-family:monospace;font-size:12px;">TDP ↗</a>` : '';
      const profileLink = `<a href="${BASE}/team?id=${team.id}&from=teams" style="color:#3b82f6;font-family:monospace;font-size:12px;">View profile ↗</a>`;

      const popup = `
        <div style="font-family:'DM Sans',sans-serif;min-width:180px;">
          <div style="font-weight:600;font-size:14px;margin-bottom:4px;">${team.name}</div>
          <div style="font-size:12px;color:#666;margin-bottom:2px;">${team.institution || ''}</div>
          <div style="font-size:12px;color:#666;margin-bottom:4px;">${[team.city, team.country].filter(Boolean).join(', ')}</div>
          ${lastSeen ? `<div style="font-size:11px;color:#999;margin-bottom:6px;">${lastSeen}</div>` : ''}
          <div style="font-size:12px;margin-bottom:4px;">${profileLink}</div>
          <div style="font-size:12px;">${[websiteLink, tdpLink].filter(Boolean).join(' &nbsp;·&nbsp; ')}</div>
        </div>`;

      markers[team.id] = L.marker([lat, lng], { icon: markerIcon }).bindPopup(popup);
    }

    updateMapAndGrid(2022);
  }

  load();
</script>
