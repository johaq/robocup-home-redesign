---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="RoboCup@Home — Team" description="Team profile page.">

  <div class="container">
    <a id="back-link" href={`${base}/teams`} class="back-link">← Back to all teams</a>
    <div id="team-content"><p class="loading">Loading team...</p></div>
  </div>
</Base>

<script is:inline type="module" src={`${base}/assets/js/team.js`}></script>
